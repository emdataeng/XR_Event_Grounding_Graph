# Neo4j Aura credentials — copy this file to .env and fill in your values
# Find these in Neo4j Aura console → your instance → "Connect" button
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Optional Hugging Face token for higher rate limits and faster model downloads
# Create one at https://huggingface.co/settings/tokens with Read permission
HF_TOKEN=hf_your-token-here

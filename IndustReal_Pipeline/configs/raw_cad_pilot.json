        "local_path": ".tmp/industreal_pilot/source/test_p3.zip",
        "url": "https://data.4tu.nl/file/b008dd74-020d-4ea4-a8ba-7bb60769d224/31f88cb6-a2e7-44df-ac51-5aaa0a148fc3"
      }
    ]
  },
  "pilot": {
    "name": "raw_cad_pilot",
    "base_clips": [
      "03_assy_0_1",
      "03_assy_1_3"
    ],
    "target_clip_count": 3,
    "minimum_clip_count": 2,
    "allow_base_slice_fallback": true
  },
  "storage_limits_mb": {
    "compressed_slice_cap": 600,
    "extracted_slice_cap": 2500,
    "repo_full_archive_cap": 0
  },
  "slice_rules": {
    "install_pre": 60,
    "install_post": 30,
    "error_pre": 120,
    "error_post": 60,
    "context_head": 30,
    "context_tail": 30,
    "merge_gap": 20
  },
  "detector": {
    "default_backend": "oracle_od",
    "oracle_backend": "oracle_od",
    "oracle_mode": "state_labels",
    "model_ids": [
      "openmmlab-community/mm_grounding_dino_base_all",
      "IDEA-Research/grounding-dino-base"
    ],
    "box_threshold": 0.25,
    "text_threshold": 0.25,
    "iou_smoothing_threshold": 0.35,
    "track_decay": 0.85
  },
  "reasoner": {
    "min_non_error_conf": 0.48,
    "top_k_states": 3,
    "step_export_mode": "direct_transitions",
    "transition_weights": {
      "stay": 0.08,
      "observed": 0.05,
      "reverse": -0.05,
      "error_entry": -0.08,
      "error_exit": -0.03
    },
    "component_presence_floor": 0.02
  },
  "evaluation": {
    "min_event_window_evidence_ratio": 0.8,
    "score_scope": "in_slice_only"
  },
  "visualization": {
    "n_samples_per_clip": 6
  },
  "cad": {
    "state_asset_pattern": "state{index}.fbx",
    "asset_families": {
      "beams_braces": "SPS-000001 - Rubber-band-driven car - Beams Braces.3mf",
      "screws_pins": "SPS-000001 - Rubber-band-driven car - Screws Pins.3mf",
      "sign_nuts_washers_pulley": "SPS-000001 - Rubber-band-driven car - Sign Nuts Washers Pulley.3mf",
      "wheels": "SPS-000001 - Rubber-band-driven car - Wheels.3mf"
    },
    "components": [
      {
        "key": "base",
        "display_name": "base",
        "state_bit_index": 0,
        "detector_group": "structures",
        "prompts": [
          "base",
          "car base",
          "vehicle base"
        ],
        "aliases": [
          "base plate"
        ],
        "asset_family": "beams_braces"
      },
      {

    "part_geometries_repo": "data/part_geometries.zip",
    "part_geometries_working": ".tmp/industreal_pilot/source/part_geometries.zip",
    "source_archives": [
      {
        "name": "test_p1",
        "split": "test",
        "local_path": ".tmp/industreal_pilot/source/test_p1.zip",
        "url": "https://data.4tu.nl/file/b008dd74-020d-4ea4-a8ba-7bb60769d224/ec7a4f94-7c1d-497d-b75a-4e694b7a9f7e"
      },
      {
        "name": "test_p2",
        "split": "test",
        "local_path": ".tmp/industreal_pilot/source/test_p2.zip",
        "url": "https://data.4tu.nl/file/b008dd74-020d-4ea4-a8ba-7bb60769d224/d07789b6-83b1-429d-be0c-95edba210757"
